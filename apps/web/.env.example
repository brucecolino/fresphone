# ===== FreshPhone web — variabili d'ambiente =====
# Copia in .env.local e compila. Su Vercel: Project Settings → Environment Variables.

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (Postgres — Vercel Postgres / Neon / Supabase)
DATABASE_URL=

# Auth.js (NextAuth v5)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Email admin separate da virgola (accesso all'area /admin)
ADMIN_EMAILS=marktorket@gmail.com

# Stripe (usa chiavi TEST finché non sei live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_SIXMONTH=
STRIPE_PRICE_YEARLY=
STRIPE_PRICE_LIFETIME=

# PayPal (sandbox finché non sei live)
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Firma licenze (Ed25519 PEM). Genera con: pnpm --filter @freshphone/web keys
# La chiave privata resta solo sul server; quella pubblica viene inclusa anche nell'app desktop.
LICENSE_PRIVATE_KEY=
NEXT_PUBLIC_LICENSE_PUBLIC_KEY=

# Email (Resend) — opzionale: senza chiave le email vengono solo loggate (stub)
RESEND_API_KEY=
MAIL_FROM=FreshPhone <noreply@freshphone.app>
